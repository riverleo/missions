# Supabase
# For production, use your Supabase project URL and publishable key
# Get these from: https://supabase.com/dashboard/project/_/settings/api-keys
PUBLIC_SUPABASE_URL=your_supabase_project_url
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Cloudflare Tunnel for local Linear webhook development
# Quick tunnel runs automatically when no values are set below.
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_CONFIG_PATH=
CLOUDFLARED_TUNNEL_NAME=
CLOUDFLARED_PUBLIC_HOSTNAME=

# Linear webhook verification
# Leave LINEAR_WEBHOOK_SECRET empty only for local manual testing.
LINEAR_WEBHOOK_SECRET=
LINEAR_WEBHOOK_MAX_AGE_MS=60000
LINEAR_API_KEY=
GITHUB_PR_MERGE_METHOD=squash
CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
